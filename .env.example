# Application
PORT=3000

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# SNS SMS defaults (optional)
# Allowed values: Promotional | Transactional
SNS_SMS_TYPE=Transactional
# Sender ID shown to the recipient (supported countries only)
SNS_SENDER_ID=
